{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/var/data/alufran_api.db"
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "AlufranConsole",
    "Audience": "AlufranConsoleApp",
    "ExpireMinutes": 480
  }
}
