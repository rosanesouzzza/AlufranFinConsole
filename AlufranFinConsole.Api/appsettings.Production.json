{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD};Pooling=true;Maximum Pool Size=100;SSL Mode=Require;"
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "AlufranConsole",
    "Audience": "AlufranConsoleApp",
    "ExpireMinutes": 480
  }
}
